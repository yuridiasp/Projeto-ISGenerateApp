{
  "name": "ISGeA",
  "version": "1.0.1",
  "description": "Aplicação desenvolvida para automação de separação das intimações provenientes de IS, cadastro e validação.",
  "main": "dist/src/main.js",
  "scripts": {
    "clean": "rimraf dist",
    "test": "dotenvx run -f .env.test --quiet -- jest",
    "test:watch": "dotenvx run -f .env.test --quiet -- jest --watchAll --detectOpenHandles",
    "test:register": "dotenvx run -f .env.test --quiet -- npx jest test/integration/intimationRegister.create.test.ts",
    "test:report": "dotenvx run -f .env.test --quiet -- npx jest test/integration/intimationReporter.validateIntimation.test.ts",
    "test:split": "dotenvx run -f .env.test --quiet -- npx jest test/integration/splitIS.test.ts",
    "test:unit": "dotenvx run -f .env.test --quiet -- npx jest test/unit",
    "build": "npm run clean && babel src --extensions \".ts,.tsx,.js\" --out-dir dist/src --source-maps inline",
    "start": "npm run build && electron .",
    "package": "cross-env NODE_ENV=production npm run build && electron-forge package",
    "make": "cross-env NODE_ENV=production npm run build && electron-forge make",
    "publish": "electron-forge publish"
  },
  "author": "Yuri Dias Pereira Gomes",
  "license": "MIT",
  "dependencies": {
    "axios": "1.16.1",
    "axios-retry": "4.5.0",
    "dayjs": "1.11.21",
    "dotenv": "17.2.2",
    "electron-squirrel-startup": "1.0.1",
    "html-to-docx": "1.8.0",
    "iconv-lite": "0.7.2",
    "jsdom": "29.1.1",
    "mammoth": "1.12.0",
    "pdf-parse": "2.4.5",
    "update-electron-app": "3.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xlsx-js-style": "1.2.0"
  },
  "devDependencies": {
    "@babel/cli": "7.28.3",
    "@babel/core": "7.25.7",
    "@babel/preset-env": "7.25.7",
    "@babel/preset-typescript": "7.25.7",
    "@dotenvx/dotenvx": "1.69.1",
    "@electron-forge/cli": "7.6.1",
    "@electron-forge/core": "7.6.1",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-rpm": "7.9.0",
    "@electron-forge/maker-squirrel": "7.6.1",
    "@electron-forge/maker-zip": "7.6.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.6.1",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/publisher-github": "7.11.2",
    "@types/electron": "1.6.12",
    "@types/html-to-docx": "1.8.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "25.9.1",
    "babel-jest": "30.1.2",
    "babel-plugin-add-import-extension": "1.6.0",
    "babel-plugin-module-resolver": "5.0.2",
    "cross-env": "10.0.0",
    "electron": "42.2.0",
    "jest": "30.1.3",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsx": "4.19.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "tar": "7.5.1",
    "tmp": "0.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yuridiasp/Projeto-ISGenerateApp.git"
  }
}
